# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/a3taxi

# Auth
JWT_SECRET=change-me
ADMIN_DEFAULT_PASSWORD=change-me

# Google Maps — server-side key used by backend/src/services/distance.js to call the
# Routes API (computeRoutes) for the booking-form price estimate. Requires the Routes
# API enabled + billing on the Google Cloud project (separate from Maps JavaScript API
# and Places API (New), which the frontend key handles). Distinct from the frontend's
# VITE_GOOGLE_MAPS_API_KEY in frontend/.env — keep this one server-side only.
GOOGLE_MAPS_API_KEY=

# Web Push (driver job notifications) — VAPID key pair identifies this server to
# push services. Generate once with: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# SMS Gate (SMS confirmations) — self-hosted Android app, see sms-gate.app
# Local mode: http://<phone-lan-ip>:8080  |  Cloud mode: https://api.sms-gate.app/3rdparty/v1
SMS_GATE_BASE_URL=
SMS_GATE_USERNAME=
SMS_GATE_PASSWORD=

# File storage (receipt photos) — Cloudflare R2, an S3-compatible bucket. Create a
# bucket, an API token (Account ID, Access Key ID, Secret Access Key), and enable
# public read access (or an r2.dev public URL) so receipt links work for admins.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Frontend
FRONTEND_URL=http://localhost:5173
